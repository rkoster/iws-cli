# Start incus workspace container if not running, then open in new Ghost window
# Default instance name (can be overridden by exporting INST)
INST=${INST:-workspace}

# Simple argument parsing: support `--update` to refresh the image and recreate the instance.
UPDATE=no
if [ "${1:-}" = "--update" ]; then
  UPDATE=yes
  shift 1
fi

IMAGE=${IMAGE:-oci-ghcr:rkoster/workspace:latest}

# Detect a server remote (protocol 'incus') and build a prefix to target remote operations
SERVER_REMOTE=$(incus remote list --format=json 2>/dev/null | jq -r '
  to_entries[] | select(.value.Protocol == "incus" and (.value.Static | not)) | .key
' 2>/dev/null | head -1)
if [ -n "$SERVER_REMOTE" ]; then
  SERVER_PREFIX="$SERVER_REMOTE:"
else
  SERVER_PREFIX=""
  # On non-Linux platforms (e.g. macOS), a remote Incus server is required
  if [ "$(uname)" != "Linux" ]; then
    echo "Error: No remote Incus server detected." >&2
    echo "On macOS, a remote server is required to run containers." >&2
    echo "Configure one with: incus remote add <name> <url>" >&2
    exit 1
  fi
fi

# Image pull helper: copy the requested image into the target remote (server or local)
pull_image() {
  echo "Pulling latest image '$IMAGE' into target..."

  if [ -n "$SERVER_REMOTE" ]; then
    echo "-> copying to server remote '$SERVER_REMOTE' with alias rkoster-workspace-latest"
    # Delete old alias if it exists on the server remote (use full remote:alias syntax)
    incus image alias delete "${SERVER_REMOTE}:rkoster-workspace-latest" 2>/dev/null || true
    if incus image copy "$IMAGE" "$SERVER_REMOTE:" --alias rkoster-workspace-latest; then
      LAUNCH_IMAGE="${SERVER_PREFIX}rkoster-workspace-latest"
      return 0
    else
      echo "Warning: failed to copy image '$IMAGE' to server remote '$SERVER_REMOTE'." >&2
    fi
  fi

  # Fallback to local image store
  echo "-> copying to local store with alias rkoster-workspace-latest"
  # Delete old alias if it exists on local remote
  incus image alias delete local:rkoster-workspace-latest 2>/dev/null || true
  if incus image copy "$IMAGE" local: --alias rkoster-workspace-latest; then
    LAUNCH_IMAGE=local:rkoster-workspace-latest
    return 0
  else
    echo "Warning: failed to copy image '$IMAGE' to local:. Falling back to raw image reference." >&2
    LAUNCH_IMAGE="$IMAGE"
    return 1
  fi
}

# Ensure GHCR (GitHub Container Registry) is configured as an OCI remote named 'oci-ghcr'
GHCR_REMOTE=oci-ghcr
if ! incus remote get "$GHCR_REMOTE" >/dev/null 2>&1; then
  echo "Configuring incus remote '$GHCR_REMOTE' for GitHub Container Registry..."
  incus remote add "$GHCR_REMOTE" https://ghcr.io --protocol=oci
fi

# If update requested, perform delete+pull before attempting to (re)launch.
if [ "$UPDATE" = "yes" ]; then
  echo "Update requested: refreshing workspace image and recreating instance '$INST'"

  # Remove instance if it exists
  if incus info "$INST" >/dev/null 2>&1; then
    echo "Destroying existing instance '$INST'..."
    incus delete "$INST" --force || true

    # Wait for the instance to be gone
    for i in {1..60}; do
      if ! incus info "$INST" >/dev/null 2>&1; then
        break
      fi
      echo "Waiting for instance '$INST' to be removed... (attempt $i)"
      sleep 1
    done
  fi

  # Pull latest image into the appropriate store and set LAUNCH_IMAGE
  if ! pull_image; then
    echo "Error: failed to pull latest image. Update aborted." >&2
    exit 1
  fi
fi

if ! incus info "$INST" &>/dev/null; then
  echo "Launching $INST"
  
  # Determine storage pool (prefer 'local') and create storage volume if it doesn't exist
  POOL=local
  if ! incus storage list "$POOL" >/dev/null 2>&1; then
    # Fallback: pick the first storage pool from the table output
    POOL=$(incus storage list 2>/dev/null | awk -F'|' 'NR==4{gsub(/^[ \t]+|[ \t]+$/,"",$2); print $2}')
    POOL=${POOL:-local}
  fi

  # Create storage volumes if they don't exist: config and workspace
  if ! incus storage volume show "$POOL" workspace-config >/dev/null 2>&1; then
    echo "Creating config volume on pool '$POOL'..."
    incus storage volume create "$POOL" workspace-config
  fi

  if ! incus storage volume show "$POOL" workspace >/dev/null 2>&1; then
    echo "Creating workspace volume on pool '$POOL'..."
    incus storage volume create "$POOL" workspace
  fi
  
  # Launch the workspace instance using the OCI image configured in $IMAGE (default to oci-ghcr:rkoster/workspace:latest)
  IMAGE=${IMAGE:-oci-ghcr:rkoster/workspace:latest}
  echo "Preparing to launch instance '$INST' from image '$IMAGE' on pool '$POOL'..."

  echo "Launching instance '$INST' from image '${LAUNCH_IMAGE:-$IMAGE}' on pool '$POOL'..."
  # Determine instance target: use server prefix if present
  TARGET_INSTANCE="${SERVER_PREFIX}${INST}"
  if ! incus launch "${LAUNCH_IMAGE:-$IMAGE}" "$TARGET_INSTANCE" --network incusbr0 -s "$POOL" -c security.nesting=true; then
    # If launch failed, check whether the instance record exists (maybe a create op is in progress).
    if incus info "$TARGET_INSTANCE" >/dev/null 2>&1; then
      echo "Instance '$TARGET_INSTANCE' exists (create may be in progress). Proceeding to attach volume."
    else
      echo "Failed to launch instance from image '${LAUNCH_IMAGE:-$IMAGE}'. Check that the remote '$GHCR_REMOTE' is configured and accessible." >&2
      exit 1
    fi
  fi

  # Attach the config and workspace volumes as disk devices (post-launch)
  if incus info "$TARGET_INSTANCE" >/dev/null 2>&1; then
    echo "Attaching config volume to instance '$TARGET_INSTANCE'..."
    incus config device add "$TARGET_INSTANCE" config disk pool="$POOL" source=workspace-config path=/home/ruben/.config-volume || \
      incus config device set "$TARGET_INSTANCE" config source=workspace-config path=/home/ruben/.config-volume || true

    echo "Attaching workspace volume to instance '$TARGET_INSTANCE' at ~/workspace..."
    incus config device add "$TARGET_INSTANCE" workspace disk pool="$POOL" source=workspace path=/home/ruben/workspace || \
      incus config device set "$TARGET_INSTANCE" workspace source=workspace path=/home/ruben/workspace || true
  fi
  
  # Wait for container to be ready
  echo "Waiting for container to be ready..."
  sleep 2
  
  # Initialize volume directories with proper ownership and create symlinks
  echo "Initializing config volume..."
  # Source profile.d scripts if available to get the correct PATH.
  incus exec "$TARGET_INSTANCE" -- /bin/sh -c '
    # Source profile.d scripts to set PATH
    for script in /etc/profile.d/*.sh; do
      [ -f "$script" ] && . "$script"
    done

    # Helper to create a volume-backed symlink
    # Usage: init_symlink <target_on_volume> <link_path>
    init_symlink() {
      target="$1"
      link="$2"
      # Ensure target exists
      [ -d "$target" ] || mkdir -p "$target"

      if [ -L "$link" ]; then
        # If symlink exists but points elsewhere, recreate it
        if [ "$(readlink "$link")" != "$target" ]; then
          rm -f "$link" || true
          ln -s "$target" "$link" || true
        fi
      else
        if [ -e "$link" ]; then
          # Move existing dir/file into the target (preserve content)
          mv "$link" "$target" 2>/dev/null || true
        fi
        mkdir -p "$(dirname "$link")" || true
        ln -s "$target" "$link" || true
      fi
    }

    # Create config-volume dirs and symlinks from ~/.config
    init_config_symlinks() {
      names="gh gh-copilot github-copilot incus"
      mkdir -p /home/ruben/.config || true
      for name in $names; do
        init_symlink /home/ruben/.config-volume/$name /home/ruben/.config/$name
      done
    }

    # Persist app state/data dirs on the volume
    init_state_symlinks() {
      init_symlink /home/ruben/.config-volume/opencode-data /home/ruben/.local/share/opencode
      init_symlink /home/ruben/.config-volume/opencode-state /home/ruben/.local/state/opencode
      init_symlink /home/ruben/.config-volume/gh-state /home/ruben/.local/state/gh

      # Persist zsh history (single file, not a directory)
      target=/home/ruben/.config-volume/zsh_history
      link=/home/ruben/.zsh_history
      [ -f "$target" ] || touch "$target"
      if [ -L "$link" ]; then
        if [ "$(readlink "$link")" != "$target" ]; then
          rm -f "$link" || true
          ln -s "$target" "$link" || true
        fi
      else
        if [ -f "$link" ]; then
          # Append existing history into the volume file
          cat "$link" >> "$target" 2>/dev/null || true
          rm -f "$link" || true
        fi
        ln -s "$target" "$link" || true
      fi
    }

    # Perform initialization unconditionally; basic commands are provided by the image
    init_config_symlinks
    init_state_symlinks
    mkdir -p /home/ruben/workspace || true
    chown -R 1000:1000 /home/ruben/.config-volume /home/ruben/workspace || true
  '

elif [ "$(incus info workspace | grep '^Status:' | awk '{print $2}')" != "RUNNING" ]; then
  echo "Starting workspace"
  incus start workspace
fi

ghostty --wait-after-command --command="incus exec $INST -- /bin/sh -c 'for s in /etc/profile.d/*.sh; do [ -f \"\$s\" ] && . \"\$s\"; done; for p in /nix/store/*-home-manager-path/bin; do export PATH=\"\$p:\$PATH\"; done; if command -v zsh >/dev/null 2>&1; then TERM=xterm-256color exec zsh -lc \"exec tmux new-session -A -s main\"; else TERM=xterm-256color exec /bin/sh -c \"exec tmux new-session -A -s main\"; fi'" &>/dev/null &
